# API-ключи (любой из них даёт полный доступ как admin). Сгенерировать: python -m scripts.generate_api_key
MEDHOUSE_API_KEY_1=
MEDHOUSE_API_KEY_2=
MEDHOUSE_API_KEY_3=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# БД
DATABASE_URL=sqlite:///./medhouse.db

# Компании
COMPANY_MEDHOUSE=Медхаус
COMPANY_SWISS=Свисс Энерджи

