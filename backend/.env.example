# Логирование: уровень DEBUG|INFO|WARNING|ERROR; опционально файл (путь относительно backend/ или абсолютный)
# LOG_LEVEL=INFO
# LOG_FILE=logs/app.log
# В проде (Railway): список разрешённых доменов через запятую, например https://medhouse.vercel.app (иначе запросы с фронта могут блокироваться CORS)
# CORS_ORIGINS=https://your-app.vercel.app

# Секрет для JWT (сгенерируйте свой: openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-in-production

# API-ключи (любой из них даёт полный доступ как admin). Сгенерировать: python -m scripts.generate_api_key
MEDHOUSE_API_KEY_1=
MEDHOUSE_API_KEY_2=
MEDHOUSE_API_KEY_3=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# БД (локально — SQLite; прод — Postgres из Supabase)
DATABASE_URL=sqlite:///./medhouse.db
# Для прода: Supabase → Settings → Database → Connection string (URI). Формат: postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_URL и SUPABASE_ANON_KEY — из вкладки API Keys (для будущего клиентского доступа). Service Role Key — в API settings, если понадобится серверный доступ.
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJ...

# Компании
COMPANY_MEDHOUSE=Медхаус
COMPANY_SWISS=Свисс Энерджи

# Путь к папке «база для данных» (по умолчанию: <корень проекта>/база для данных)
# DATA_BASE_PATH=

# Google Drive (опционально)
# Проект: pharmacy-bot-487900. Положите service_account_pharmacy_bot.json в backend/
# GOOGLE_DRIVE_CREDENTIALS_FILE=credentials.json
# GOOGLE_DRIVE_TOKEN_FILE=token.json
# Папка ПНЛ (уже задана по умолчанию)
# GOOGLE_DRIVE_PNL_FOLDER_ID=1f-3_NyHFIRBGtXf8-aoJBy4yjtNYN6rx
# Папки с форматом бюджета БДР: в названии папки в конце «Евгений» (Медхаус) или «Алмас» (Свисс)
# GOOGLE_DRIVE_EVGENIJ_FOLDER_ID=
# GOOGLE_DRIVE_ALMAS_FOLDER_ID=
# МХ формат — книга (реал 8 мес, Продажи дистр, Касса, Банк, Оста, Дзад); ID задан по умолчанию
# GOOGLE_MX_SPREADSHEET_ID=1G5atWyRUOxr23iZ3Q8txMRo_DrdjdCEo9VVQfVBAl6Q
# Заявка фармацевты (таблица остатков) — ID уже задан по умолчанию
# GOOGLE_ZAJAVKA_FARMACEVTOV_SPREADSHEET_ID=1XSFq5PbJadJR21h6Z9z3hhfnGu4tEl93K6WEXUYutdI
# GOOGLE_ZAJAVKA_SHEET_GID=1144561640
